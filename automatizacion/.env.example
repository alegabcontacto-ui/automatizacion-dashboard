# Copiar este archivo como .env y rellenar los valores reales
# NUNCA subir el .env real a Git

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=TU_PASSWORD_AQUI
MYSQL_DATABASE=cotizaciones_imss

